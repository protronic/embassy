{
  "_comment": "JSON-driven CANopen node for the OxivGL host (json_node_gui). Object dictionary + Rhai scripts + SocketCAN; the GUI shows the OD live and provides the virtual process data (LEDs, Taster). 'access' is the bus/UI view (rw/wo writable, ro/const not) — scripts are device-internal and may write 'ro' entries; only 'const' is rejected.",
  "node_id": 16,
  "name": "IO-Modul",
  "description": "Host demo node: Taster = digital input 0x6000, virtual LEDs = digital output 0x6200, OD changes go out as CAN 'PDO' frames on vcan0",
  "can": {
    "mode": "socketcan",
    "channel": "vcan0",
    "tpdo": "0x180",
    "rpdo": "0x200",
    "heartbeat": true
  },
  "datapoints": [
    { "index": "0x1000", "sub": 0, "name": "device_type", "type": "u32", "access": "const", "value": 0 },
    { "index": "0x1008", "sub": 0, "name": "device_name", "type": "str", "access": "const", "value": "JSON-Rhai Host-Modul" },
    { "index": "0x1017", "sub": 0, "name": "heartbeat_ms", "type": "u16", "access": "rw", "value": 2000, "step": 100 },
    { "index": "0x2100", "sub": 0, "name": "cycle_counter", "type": "i32", "access": "ro", "value": 0 },
    { "index": "0x2101", "sub": 0, "name": "blink_on", "type": "bool", "access": "rw", "value": true },
    { "index": "0x6000", "sub": 1, "name": "din_button", "type": "u8", "access": "ro", "value": 0 },
    { "index": "0x6200", "sub": 1, "name": "dout_leds", "type": "u8", "access": "rw", "value": 0 }
  ],
  "scripts": [
    {
      "name": "init",
      "run": "once",
      "script": [
        "print(\"node '\" + node_name() + \"' (id \" + node_id() + \") started\");",
        "od_dump();",
        "leds(0);"
      ]
    },
    {
      "name": "io",
      "run": "cyclic",
      "period_ms": 100,
      "script": [
        "od_write(0x6000, 1, button());",
        "leds(od_read(0x6200, 1));"
      ]
    },
    {
      "name": "logic",
      "run": "cyclic",
      "period_ms": 500,
      "script": [
        "let c = od_read(0x2100, 0) + 1;",
        "od_write(0x2100, 0, c);",
        "if get(\"din_button\") != 0 {",
        "    set(\"dout_leds\", 15);",
        "} else if get(\"blink_on\") {",
        "    set(\"dout_leds\", 1 << (c % 4));",
        "} else {",
        "    set(\"dout_leds\", 0);",
        "}"
      ]
    },
    {
      "name": "heartbeat",
      "run": "cyclic",
      "period_ms": 2000,
      "script": [
        "print(\"hb: uptime=\" + uptime_ms() / 1000 + \"s cycles=\" + get(\"cycle_counter\") + \" din=\" + get(\"din_button\") + \" dout=\" + get(\"dout_leds\"));"
      ]
    }
  ]
}
